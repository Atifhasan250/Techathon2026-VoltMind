# Public URL used by the Discord bot to reach the shared backend.
APP_BASE_URL=http://localhost:3000

# Optional MongoDB Atlas history persistence. Without this, live data and
# session energy still work, but history resets when the server restarts.
MONGODB_URI=

# Discord bot configuration (needed in the Discord milestone).
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_alert_channel_id

# Optional LLM humanization (needed in the Discord milestone).
GEMINI_API_KEY_1=your_first_gemini_api_key
GEMINI_API_KEY_2=your_second_gemini_api_key
GEMINI_API_KEY_3=your_third_gemini_api_key

# Optional; defaults to gemini-3.5-flash.
GEMINI_MODEL=gemini-3.5-flash
